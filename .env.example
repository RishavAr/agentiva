AGENTSHIELD_MODE=shadow
AGENTSHIELD_POLICY_PATH=policies/default.yaml
AGENTSHIELD_RATE_LIMIT_PER_MINUTE=100
AGENTSHIELD_DATABASE_URL=sqlite+aiosqlite:///./agentshield.db

